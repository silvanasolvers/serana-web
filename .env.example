# Supabase (shared with dashboard-Serana — project tjjrnpwwfvmsukfrfchr).
# The anon key is the only credential the public site needs; service-role keys
# stay server-side only.
VITE_SUPABASE_URL="https://tjjrnpwwfvmsukfrfchr.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="server-only-service-role-key"

# Mercado Pago. The public key is bundled in the browser; the other two values
# are server-only. MP_WEBHOOK_SECRET is mandatory in production so every
# payment notification can be authenticated before reconciliation.
VITE_MP_PUBLIC_KEY=
MP_ACCESS_TOKEN="APP_USR-your-production-access-token"
MP_WEBHOOK_URL="https://serana.solversai.cloud/api/webhooks/mercadopago"
MP_WEBHOOK_SECRET="your-webhook-secret-signature"

# Optional: AI / chatbot (server-side only)
OLLAMA_API_KEY="your-ollama-api-key"
OLLAMA_MODEL="deepseek-v4-flash"

# Optional: deployed URL for self-referential links / OAuth callbacks
APP_URL="https://serana.food"
